  "keyFeatures": [
    "14-agent pipeline with parallel execution for scene generation",
    "Google Search grounding for historical accuracy verification",
    "Character interactions with voice-differentiated dialog",
    "Temporal navigation (forward/backward time travel)",
    "3-tier image generation fallback (Google Imagen → OpenRouter Flux → Pollinations.ai)",
    "Quality presets (hyper/balanced/hd/gemini3) for speed/quality tradeoff",
    "JWT authentication with Apple Sign-In support",
    "Credit-based billing system with customizable hooks",
    "Streaming generation with SSE progress updates",
    "Critique-retry loop for dialog quality assurance"
  ],
  "publicApiSurface": [
    "POST /api/v1/timepoints/generate/stream - Generate scene with streaming progress",
    "POST /api/v1/timepoints/generate/sync - Generate scene (blocking)",
    "POST /api/v1/timepoints/generate - Generate scene (background)",
    "GET /api/v1/timepoints/{id} - Retrieve a scene",
    "PATCH /api/v1/timepoints/{id}/visibility - Set scene visibility",
    "POST /api/v1/interactions/{id}/chat - Chat with character",
    "POST /api/v1/temporal/{id}/next - Jump forward in time",
    "POST /api/v1/temporal/{id}/prior - Jump backward in time",
    "GET /api/v1/temporal/{id}/sequence - Get timeline sequence",
    "POST /api/v1/auth/apple - Apple Sign-In authentication",
    "POST /api/v1/auth/refresh - Refresh access token",
    "GET /api/v1/auth/me - Get current user profile",
    "GET /api/v1/credits/balance - Get credit balance",
    "GET /api/v1/credits/costs - Get credit cost table",
    "GET /api/v1/users/me/timepoints - List user's scenes",
    "POST /api/v1/users/resolve - Resolve user by external_id"
  ]
}
